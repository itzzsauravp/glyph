{
  "name": "glyph",
  "displayName": "glyph",
  "description": "A simple AI helper tool to analyze, code and document for you.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "glyph.test",
        "title": "Glyph start(test)"
      },
      {
        "command": "glyph.code_generator",
        "title": "Glyph: Code Generator"
      },
      {
        "command": "glyph.docs_generator",
        "title": "Glyph: Docs Generator"
      }
    ],
    "configuration": {
      "title": "Glyph",
      "properties": {
        "glyph.modelName": {
          "type": "string",
          "default": "qwen2.5-coder:3b",
          "description": "The name of the Ollama model to use for generation."
        },
        "glyph.base_url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The URL of your Ollama instance."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
