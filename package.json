{
    "name": "glyph",
    "license": "MIT",
    "displayName": "Glyph: Micro AI Helper",
    "publisher": "sauravparajulee",
    "description": "A privacy-first, backend-agnostic AI assistant for code generation, documentation, and brainstorming.",
    "version": "0.3.1",
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/itzzsauravp/glyph"
    },
    "categories": [
        "Programming Languages",
        "Machine Learning",
        "Snippets"
    ],
    "keywords": [
        "ollama",
        "local ai",
        "documentation",
        "privacy",
        "refactor"
    ],
    "engines": {
        "vscode": "^1.110.0"
    },
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "glyph.test",
                "title": "Glyph: Start (Test)"
            },
            {
                "command": "glyph.code",
                "title": "Glyph: Code Generate"
            },
            {
                "command": "glyph.docs",
                "title": "Glyph: Docs Generate"
            },
            {
                "command": "glyph.brainstorm",
                "title": "Glyph: Brainstorm",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "glyph.reload",
                "title": "Glyph: Reload Config"
            },
            {
                "command": "glyph.model_select",
                "title": "Glyph: Model Select"
            },
            {
                "command": "glyph.cloud_provider_orchestrator",
                "title": "Glyph: Cloud Provider Orchestrator"
            },
            {
                "command": "glyph.setup_custom_model",
                "title": "Glyph: Setup Custom Model & API Key"
            },
            {
                "command": "glyph.manage_api_keys",
                "title": "Glyph: Manage / Delete API Keys"
            },
            {
                "command": "glyph.run_diagnostics",
                "title": "Glyph: Run Diagnostics"
            }
        ],
        "configuration": {
            "title": "Glyph",
            "properties": {
                "glyph.modelName": {
                    "type": "string",
                    "default": "",
                    "description": "The model identifier to use for code/docs generation (e.g. llama3.2, gpt-4o, claude-sonnet-4-20250514)."
                },
                "glyph.embeddingModelName": {
                    "type": "string",
                    "default": "",
                    "description": "The model identifier to use for vector embeddings (e.g. nomic-embed-text, text-embedding-3-small)."
                },
                "glyph.base_url": {
                    "type": "string",
                    "default": "http://localhost:11434",
                    "description": "Base URL for your AI provider API (e.g. http://localhost:11434 for Ollama, https://api.openai.com for OpenAI)."
                },
                "glyph.autoSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically save the file after code/docs generation completes."
                },
                "glyph.usingCloudOrchestrator": {
                    "type": "boolean",
                    "default": false,
                    "description": "Only check this if not using local model"
                },
                "glyph.providerType": {
                    "type": "string",
                    "enum": [
                        "Ollama",
                        "LM Studio",
                        "OpenRouter",
                        "OpenAI",
                        "Anthropic",
                        "Google"
                    ],
                    "default": "Ollama",
                    "description": "Choose the LLM provider to use."
                }
            }
        },
        "submenus": [
            {
                "id": "glyph.actions",
                "label": "Glyph"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "glyph.actions",
                    "group": "1_modification"
                }
            ],
            "glyph.actions": [
                {
                    "command": "glyph.code",
                    "group": "1_actions"
                },
                {
                    "command": "glyph.docs",
                    "group": "1_actions"
                },
                {
                    "command": "glyph.brainstorm",
                    "group": "1_actions"
                },
                {
                    "command": "glyph.test",
                    "group": "2_diagnostics"
                },
                {
                    "command": "glyph.model_select",
                    "group": "3_config"
                },
                {
                    "command": "glyph.cloud_provider_orchestrator",
                    "group": "3_config"
                },
                {
                    "command": "glyph.setup_custom_model",
                    "group": "3_config"
                },
                {
                    "command": "glyph.manage_api_keys",
                    "group": "3_config"
                },
                {
                    "command": "glyph.run_diagnostics",
                    "group": "2_diagnostics"
                }
            ]
        }
    },
    "scripts": {
        "release": "npm run compile && npx vsce package",
        "vscode:prepublish": "npm run package",
        "compile": "webpack && mkdir -p dist/webview && cp -r src/webview/brainstorm dist/webview/",
        "watch": "webpack --watch",
        "package": "npm run compile && webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/highlight.js": "^9.12.4",
        "@types/markdown-it": "^14.1.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.110.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "eslint": "^9.39.3",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "webpack": "^5.105.3",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.66",
        "@ai-sdk/google": "^3.0.58",
        "@ai-sdk/openai": "^3.0.50",
        "@lancedb/lancedb": "^0.27.2",
        "ai": "^6.0.146",
        "highlight.js": "^11.11.1",
        "markdown-it": "^14.1.1",
        "tree-node-cli": "^3.0.0"
    }
}
